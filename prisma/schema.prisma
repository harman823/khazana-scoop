generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = 5
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id          String      @id
  name        String
  slug        String      @unique
  productType String
  category    String
  description String
  price       Int
  image       String?
  badge       String?
  icon        String?
  color       String?
  status      String      @default("active")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  variants    Variant[]
  orderItems  OrderItem[]
  reviews     Review[]
  promotions  PromotionProduct[]

  @@index([productType, status])
  @@index([category, status])
  @@index([color, status])
  @@index([price, status])
}

model Variant {
  id                String   @id
  productId         String
  name              String
  tier              String
  itemCount         String
  minItems          Int
  maxItems          Int
  surpriseGiftCount Int      @default(0)
  rulesJson         String   @default("[]")
  price             Int
  compareAtPrice    Int?
  badge             String?
  line              String?
  isDefault         Boolean  @default(false)
  sortOrder         Int      @default(0)
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([productId, sortOrder])
}

model Customer {
  id           String   @id
  authUserId   String?  @unique
  name         String
  phone        String
  email        String   @unique
  address      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
  reviews      Review[]

  @@index([authUserId])
}

model Order {
  id                String      @id
  customerId        String
  orderNote         String      @default("")
  exclusions        String      @default("")
  paymentStatus     String      @default("paid")
  fulfilmentStatus  String      @default("unfulfilled")
  subtotal          Int
  discountTotal     Int         @default(0)
  shippingFee       Int
  total             Int
  promotionCode     String?
  trackingNumber    String      @default("")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  customer          Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items             OrderItem[]

  @@index([customerId, createdAt])
  @@index([paymentStatus, createdAt])
  @@index([fulfilmentStatus, createdAt])
  @@index([promotionCode])
}

model OrderItem {
  id              String   @id
  orderId         String
  productId       String
  productName     String
  variantId       String
  variantName     String
  itemCount       String?
  quantity        Int
  price           Int
  preferencesJson String   @default("{}")
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

model InventoryItem {
  id         String   @id
  name       String
  category   String
  costPrice  Int      @default(0)
  sellPrice  Int      @default(0)
  stock      Int
  lowStockAt Int      @default(10)
  status     String   @default("active")
  image      String?
  updatedAt  DateTime @updatedAt

  @@index([category, status])
  @@index([stock])
}

model Promotion {
  id              String             @id
  name            String
  title           String
  message         String
  code            String?            @unique
  promotionType   String
  discountType    String             @default("none")
  discountValue   Int                @default(0)
  minSubtotal     Int                @default(0)
  freeShipping    Boolean            @default(false)
  automatic       Boolean            @default(true)
  bannerPlacement String             @default("top")
  startsAt        DateTime
  endsAt          DateTime?
  status          String             @default("active")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  products        PromotionProduct[]

  @@index([status, startsAt, endsAt])
  @@index([promotionType, status])
}

model PromotionProduct {
  promotionId String
  productId   String
  quantity    Int       @default(1)
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([promotionId, productId])
  @@index([productId])
}

model Review {
  id         String   @id
  productId  String
  customerId String
  rating     Int
  title      String
  body       String
  verified   Boolean  @default(false)
  status     String   @default("published")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([productId, customerId])
  @@index([productId, status, createdAt])
  @@index([customerId, createdAt])
  @@index([rating])
}
